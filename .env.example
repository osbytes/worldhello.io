# ── Database ──
# LOCAL DEV (docker compose up -d): plain Postgres, node-postgres driver auto-selected.
DATABASE_URL="postgres://worldhello:worldhello@localhost:5433/worldhello"

# PRODUCTION (Neon): comment out the local URL above and use the pooled endpoint.
# The serverless HTTP driver is auto-selected when the host contains neon.tech.
# DATABASE_URL="postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Unpooled direct endpoint (migrations only; falls back to DATABASE_URL if unset).
# DATABASE_URL_UNPOOLED="postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Upstash Redis (rate-limit counters — v1 carve-out, see DESIGN §7)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ── Email (magic-link) ── falls back in this order: Resend → SMTP → dev console.
# 1. Resend (preferred in prod)
RESEND_API_KEY=""
EMAIL_FROM="hello@worldhello.io"
# 2. SMTP via nodemailer (self-hosted / local Mailpit/MailHog). Used if RESEND_API_KEY unset.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"   # true for port 465, false for 587/STARTTLS
SMTP_USER=""
SMTP_PASS=""
# 3. If neither is set, magic links are logged to the server console (dev only).

# Public base URL for share links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Secret for signing magic-link + hashing fingerprints/IPs (required in production)
APP_SECRET="dev-only-change-me"

# Set to 1 to skip production env validation (CI builds only)
# SKIP_ENV_VALIDATION=1

# FingerprintJS (client public key optional in v1; Pro server key later)
NEXT_PUBLIC_FPJS_PUBLIC_KEY=""
